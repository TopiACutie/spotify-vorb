<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<style>
@keyframes fadeScale {
  from { opacity: 0; transform: scale(0.88); }
  to { opacity: 1; transform: scale(1); }
}
@keyframes glowPulse {
  0%, 100% { filter: drop-shadow(0 0 8px rgba(255,255,255,0.3)) drop-shadow(0 0 20px rgba(29,185,84,0.1)); }
  50% { filter: drop-shadow(0 0 14px rgba(255,255,255,0.5)) drop-shadow(0 0 30px rgba(29,185,84,0.2)); }
}
@keyframes ringRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
@keyframes shimmer {
  0% { background-position: -200% center; }
  100% { background-position: 200% center; }
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  background: radial-gradient(ellipse at 50% 40%, rgba(29,185,84,0.05) 0%, transparent 60%),
              radial-gradient(ellipse at 80% 80%, rgba(255,255,255,0.02) 0%, transparent 50%),
              #0b0b0b;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  user-select: none;
  overflow: hidden;
}
.splash {
  text-align: center;
  animation: fadeScale 0.7s ease-out;
  position: relative;
}
.logoRing {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  margin: 0 auto 28px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.logoRing::before {
  content: '';
  position: absolute;
  inset: -3px;
  border-radius: 50%;
  border: 1.5px solid rgba(255,255,255,0.08);
  border-top-color: rgba(29,185,84,0.4);
  border-right-color: rgba(255,255,255,0.15);
  animation: ringRotate 3s linear infinite;
}
.logoRing::after {
  content: '';
  position: absolute;
  inset: -8px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.04);
  border-bottom-color: rgba(29,185,84,0.2);
  border-left-color: rgba(255,255,255,0.08);
  animation: ringRotate 4s linear infinite reverse;
}
#splashLogo {
  width: 96px;
  height: 96px;
  border-radius: 50%;
  object-fit: cover;
  animation: glowPulse 2.5s ease-in-out infinite;
  box-shadow: 0 0 30px rgba(29,185,84,0.08), 0 0 60px rgba(0,0,0,0.3);
}
h1 {
  color: #ffffff;
  font-size: 34px;
  font-weight: 700;
  letter-spacing: 10px;
  text-shadow: 0 0 20px rgba(255,255,255,0.3), 0 0 60px rgba(255,255,255,0.10);
  margin-bottom: 12px;
}
.sub {
  background: linear-gradient(90deg, rgba(255,255,255,0.25), rgba(255,255,255,0.55), rgba(255,255,255,0.25));
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 3s linear infinite;
  font-size: 11px;
  letter-spacing: 6px;
  text-transform: uppercase;
  font-weight: 400;
}
.dotRow {
  margin-top: 24px;
  display: flex;
  justify-content: center;
  gap: 8px;
}
.dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  animation: dotPulse 1.8s ease-in-out infinite;
}
.dot:nth-child(2) { animation-delay: 0.3s; }
.dot:nth-child(3) { animation-delay: 0.6s; }
@keyframes dotPulse {
  0%, 100% { opacity: 0.2; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.3); background: rgba(29,185,84,0.5); }
}
.version {
  color: rgba(255,255,255,0.12);
  font-size: 10px;
  letter-spacing: 3px;
  margin-top: 32px;
  font-weight: 400;
}
</style>
</head>
<body>
<div class="splash">
  <div class="logoRing">
    <img id="splashLogo" />
  </div>
  <h1>VORB</h1>
  <div class="sub">Visualized Oscillation Radio Ball</div>
  <div class="dotRow">
    <div class="dot"></div>
    <div class="dot"></div>
    <div class="dot"></div>
  </div>
  <div class="version" id="versionLabel">v... &middot; Spotify</div>
</div>
</body>
</html>
