{
  "name": "spotify-vorb",
  "version": "3.0.1",
  "description": "Spotify VORB - Desktop audio visualizer and overlay",
  "author": "Sossi",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "obs": "electron . --obs-only",
    "build": "electron-builder && node scripts/clean-dist.js",
    "build:publish": "electron-builder --publish always && node scripts/clean-dist.js",
    "build:dir": "electron-builder --dir",
    "new-version": "node scripts/new-version.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.spotify-vorb.app",
    "productName": "Spotify VORB",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!settings"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "legalTrademarks": "",
      "requestedExecutionLevel": "asInvoker",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "fileAssociations": [],
      "extraResources": [],
      "publisherName": "Sossi"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "perMachine": true,
      "allowElevation": true,
      "include": "scripts/installer.nsh",
      "license": "LICENSE",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Spotify VORB"
    },
    "publish": {
      "provider": "github",
      "owner": "TopiACutie",
      "repo": "spotify-vorb"
    },
    "copyright": "Copyright © 2026 Sossi",
    "extraMetadata": {
      "main": "main.js"
    }
  }
}
