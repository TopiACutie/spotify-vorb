{
  "name": "spotify-vorb",
  "version": "3.6.2",
  "description": "Spotify VORB - Desktop audio visualizer and overlay",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Sossi",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "obs": "electron . --obs-only",
    "build": "electron-builder --dir && node scripts/build-inno.js && node scripts/clean-dist.js",
    "build:publish": "electron-builder --dir && node scripts/build-inno.js && node scripts/publish.js && node scripts/clean-dist.js",
    "build:dir": "electron-builder --dir",
    "build:nsis": "electron-builder && node scripts/clean-dist.js",
    "publish": "node scripts/publish.js",
    "new-version": "node scripts/new-version.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.spotify-vorb.app",
    "productName": "Spotify VORB",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!settings"
    ],
    "win": {
      "target": "dir",
      "icon": "assets/icon.ico",
      "legalTrademarks": "",
      "requestedExecutionLevel": "asInvoker",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "fileAssociations": [],
      "extraResources": [],
      "publisherName": "Sossi"
    },
    "publish": {
      "provider": "github",
      "owner": "TopiACutie",
      "repo": "spotify-vorb"
    },
    "copyright": "Copyright © 2026 Sossi",
    "extraMetadata": {
      "main": "main.js"
    }
  }
}
